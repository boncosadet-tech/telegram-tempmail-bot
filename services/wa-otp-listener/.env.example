# Directory where Baileys stores its auth / creds state.
# MUST be persistent across reboots (not /tmp) and readable only by the service user.
WA_AUTH_DIR=/home/ubuntu/.wa-otp-listener/auth

# Worker ingest endpoint. Example:
#   https://telegram-tempmail.<your-subdomain>.workers.dev/relay/gopay-otp/ingest
RELAY_URL=https://example.workers.dev/relay/gopay-otp/ingest

# Shared secret — MUST match the `GOPAY_OTP_TOKEN` var on the Worker.
# Use a long random string (>=32 chars). Rotate if leaked.
RELAY_TOKEN=change-me

# Optional: comma-separated list of WhatsApp JIDs that are allowed to
# produce OTPs. Example: "6281234567890@s.whatsapp.net,GoPay@s.whatsapp.net".
# Leave empty to accept any JID and rely on WA_OTP_REGEX filtering.
WA_EXPECTED_SENDERS=

# Optional: regex with a single capture group for the OTP digits.
# Default below matches common Indonesian OTP phrasings (GoPay, Midtrans, etc).
# Example match: "OTP kamu: 342918" -> "342918".
WA_OTP_REGEX=(?:OTP|kode|code|verif(?:ikasi|y))[^0-9]{0,20}([0-9]{4,8})

# Optional: minimum message-body length before parsing (reduces noise from stickers, reactions, etc).
WA_MIN_BODY_LENGTH=6

# Optional: log level (debug / info / warn / error).
LOG_LEVEL=info

# Optional: pair mode on first run. Either "qr" (default) or "code" (8-digit pair-code).
# When "code", set WA_PAIR_PHONE to the phone number that will own the linked device (no "+").
WA_PAIR_MODE=qr
WA_PAIR_PHONE=
